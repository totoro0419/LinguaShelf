{
  "name": "English Reading Shelf",
  "short_name": "Reading Shelf",
  "description": "English reading app with a local bookshelf and contextual dictionary.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#f6f8f7",
  "theme_color": "#146c67",
  "orientation": "any",
  "icons": [
